                    "request": {
                        "method": "POST",
                        "header": [],
                        "body": {
                            "mode": "raw",
                            "raw": "{\n  \"courseId\": \"<COURSE_ID>\",\n  \"semesterId\": \"<SEMESTER_ID>\",\n  \"schedule\": \"Mon/Wed 10:00\",\n  \"classroom\": \"Hall A\",\n  \"capacity\": 30\n}",
