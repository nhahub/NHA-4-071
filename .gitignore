# ==========================================
# 🌐 GLOBAL / SHARED 
# Applies to both Frontend & Backend (and OS/IDE)
# ==========================================

# Dependencies (Shared because both layers use Node/npm)
node_modules/

# OS Generated Files
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# IDE and Editor directories
.vscode/
.idea/
*.swp
*.swo
*~
.project
.classpath
.settings/

# General Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
AGENTS.md
# ==========================================
# ⚙️ BACKEND LAYER (Express.js / MongoDB)
# ==========================================

# Backend Environment Variables (CRITICAL: Never commit DB credentials or JWT secrets)
BackEndLayer/.env
BackEndLayer/.env.local
BackEndLayer/.env.*.local

# Backend Build/Compiled output (If you later add TypeScript or Babel)
BackEndLayer/dist/
BackEndLayer/build/

# Local MongoDB Data directory (In case you run a local DB dump inside the project folder)
BackEndLayer/data/

# ==========================================
# 🖥️ FRONTEND LAYER (React.js / Vite or CRA)
# ==========================================

# Frontend Environment Variables
FrontEndLayer/.env
FrontEndLayer/.env.local
FrontEndLayer/.env.development.local
FrontEndLayer/.env.test.local
FrontEndLayer/.env.production.local

# Frontend Build Output
FrontEndLayer/build/
FrontEndLayer/dist/

# Frontend Testing Coverage
FrontEndLayer/coverage/

# Frontend Misc
FrontEndLayer/.cache/
